# ─────────────────────────────────────────────────────────────────────────────
# CreatorPulse — Environment Configuration
# Copy this file to .env and fill in the values you have.
# ─────────────────────────────────────────────────────────────────────────────

# ── Mode ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=hackathon          # development | hackathon | production
DEBUG=false
DEMO_MODE=true                 # pre-load demo questions, safe fallbacks

# ── Mock / Local-source mode ──────────────────────────────────────────────────
# USE_MOCK_DATA=true  → skip Coral entirely; serve data/mock/*.json directly
# USE_LOCAL_SOURCES=true → wire Coral to local CSV files from mock JSON
#   (auto-enabled when any live API key is absent)
USE_MOCK_DATA=false
USE_LOCAL_SOURCES=true

# ── Coral ────────────────────────────────────────────────────────────────────
CORAL_PATH=coral               # path or command for the Coral CLI binary
CORAL_TIMEOUT=30
CORAL_CACHE_ENABLED=true

# ── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=             # required unless USE_MOCK_DATA=true
LLM_MODEL=claude-sonnet-4-6   # free-tier friendly; swap to opus for quality

# ── YouTube Data API v3 ──────────────────────────────────────────────────────
# Free quota: 10,000 units/day — more than enough for demo
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ── Discord Bot ───────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_IDS=

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/service_account.json

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL=300

# ── Server ────────────────────────────────────────────────────────────────────

